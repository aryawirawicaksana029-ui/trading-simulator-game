# Copy this file to .env for local `vercel dev` testing (never commit the real .env).
# In production, set these under Vercel Project Settings -> Environment Variables instead.

# From `turso db show your-db-name` (starts with libsql://)
TURSO_DATABASE_URL=libsql://your-db-name-yourorg.turso.io

# From `turso db tokens create your-db-name`
TURSO_AUTH_TOKEN=
